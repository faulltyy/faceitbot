# Get your Telegram bot token from @BotFather
TELEGRAM_BOT_TOKEN=

# Get your FACEIT API key from https://developers.faceit.com/
FACEIT_API_KEY=your-faceit-api-key

# Telegram user ID for admin access (get from @userinfobot)
ADMIN_ID=0

# PostgreSQL (default works with docker-compose)
DATABASE_URL=postgresql://postgres:postgres@postgres:5432/faceitbot

# Redis URL (default works with docker-compose)
REDIS_URL=redis://redis:6379/0
